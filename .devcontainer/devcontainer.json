{
  "name": "num-ops-dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/num-ops",
  "shutdownAction": "stopCompose",
  "forwardPorts": [
    8080,
    5432
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "redhat.vscode-yaml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "postCreateCommand": "chmod +x mvnw && ./mvnw -q -DskipTests compile"
}
